{
	"name": "vigil",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:rs": "cargo clippy --manifest-path src-tauri/Cargo.toml --workspace --all-targets -- -D warnings",
		"lint:all": "npm run lint && npm run lint:rs",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"format:rs": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
		"format:rs:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
		"format:all": "npm run format && npm run format:rs",
		"format:all:check": "npm run format:check && npm run format:rs:check",
		"tauri": "tauri"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@tauri-apps/cli": "^2.10.1",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.9",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1"
	},
	"type": "module",
	"dependencies": {
		"@tauri-apps/api": "^2.10.1"
	}
}
